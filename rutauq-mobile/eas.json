{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://REPLACE_WITH_YOUR_LAN_IP:8080/api/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REPLACE_WITH_YOUR_PRODUCTION_DOMAIN/api/v1",
        "EXPO_PUBLIC_MP_PUBLIC_KEY": "REPLACE_WITH_YOUR_REAL_MP_KEY"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REPLACE_WITH_YOUR_PRODUCTION_DOMAIN/api/v1",
        "EXPO_PUBLIC_MP_PUBLIC_KEY": "REPLACE_WITH_YOUR_REAL_MP_KEY"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID",
        "ascAppId": "REPLACE_WITH_YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_YOUR_TEAM_ID"
      }
    }
  }
}
